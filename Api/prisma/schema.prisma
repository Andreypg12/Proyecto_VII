// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Rol {
  ADMINISTRADOR
  PROFESIONAL
  CLIENTE
}

enum EstadoUsuario {
  ACTIVO
  BLOQUEADO
}

enum EstadoCita {
  PENDIENTE
  ACEPTADA
  RECHAZADA
  CANCELADA
  COMPLETADA
}

enum Modalidad {
  PRESENCIAL
  VIRTUAL
  HÍBRIDA
}

//Tablas normales

model Usuario {
  id        Int    @id @default(autoincrement())
  email     String @unique @db.VarChar(150)
  nombre    String @db.VarChar(100)
  apellidos String @db.VarChar(120)
  password  String @db.VarChar(251)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  rol    Rol           @default(CLIENTE)
  estado EstadoUsuario @default(ACTIVO)

  perfiles_profesionales PerfilProfesional[]
  citas                  Cita[]
  valoracion             Valoracion[]

  @@map("usuario")
}

model PerfilProfesional {
  id                 Int     @id @default(autoincrement())
  titulo             String  @db.VarChar(100)
  descripcion        String  @db.VarChar(500)
  tarifa_por_hora    Decimal @db.Decimal(10, 2)
  annos_experiencia  Int     @db.TinyInt
  imagen_profesional String  @default("image-not-found.jpg") @db.VarChar(255)
  disponibilidad     Boolean @default(true)
  telefono           String  @db.VarChar(100)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  modalidad Modalidad

  id_usuario Int
  usuario    Usuario @relation(fields: [id_usuario], references: [id])

  ubicaciones UbicacionProfesional[]

  especialidades Especialidad[]
  citas          Cita[]
  valoracion     Valoracion[]
  servicios      Servicio[]

  @@map("perfil_profesional")
}

model Especialidad {
  id           Int     @id @default(autoincrement())
  especialidad String  @db.VarChar(100)
  descripcion  String  @db.VarChar(200)
  estado       Boolean @default(true)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  perfiles_profesionales PerfilProfesional[]
  servicios              Servicio[]

  @@map("especialidad")
}

model Servicio {
  id                Int     @id @default(autoincrement())
  servicio          String  @db.VarChar(100)
  descripcion       String?  @db.VarChar(500)
  precio            Decimal @db.Decimal(10, 2)
  duracion_estimada Int     @db.SmallInt
  estado            Boolean @default(true)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  modalidad Modalidad

  id_profesional Int
  profesional    PerfilProfesional @relation(fields: [id_profesional], references: [id])

  id_categoria Int
  categoria    CategoriaServicio @relation(fields: [id_categoria], references: [id])

  especialidades Especialidad[]

  @@map("servicio")
}

model CategoriaServicio {
  id          Int     @id @default(autoincrement())
  categoria   String  @db.VarChar(100)
  descripcion String  @db.VarChar(200)
  estado      Boolean @default(true)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  Servicios Servicio[]

  @@map("categoria_servicio")
}

model Cita {
  id                               Int      @id @default(autoincrement())
  fecha_hora_inicio                DateTime
  fecha_hora_finalizacion_esperada DateTime
  fecha_hora_finalizacion_real     DateTime
  comentario_cliente               String?  @db.VarChar(500)
  monto_estimado                   Decimal  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  modalidad Modalidad
  estado    EstadoCita

  id_cliente Int
  cliente    Usuario @relation(fields: [id_cliente], references: [id])

  id_profesional Int
  profesional    PerfilProfesional @relation(fields: [id_profesional], references: [id])

  valoracion Valoracion[]

  @@map("cita")
}

model Valoracion {
  id         Int    @id @default(autoincrement())
  puntuacion Int    @db.TinyInt
  comentario String @db.VarChar(500)

  createdAt DateTime @default(now())
  updateAt  DateTime @default(now()) @updatedAt

  id_profesional Int
  profesional    PerfilProfesional @relation(fields: [id_profesional], references: [id])

  id_cliente Int
  cliente    Usuario @relation(fields: [id_cliente], references: [id])

  id_cita Int
  cita    Cita @relation(fields: [id_cita], references: [id])

  @@map("valoracion")
}

model UbicacionProfesional {
  id          Int    @id @default(autoincrement())
  id_distrito Int
  descripcion String @db.VarChar(500)

  distrito String @db.VarChar(200)
  canton   String @db.VarChar(200)
  ciudad   String @db.VarChar(200)

  id_profesional Int
  profesional    PerfilProfesional @relation(fields: [id_profesional], references: [id])

  @@map("ubicacion_profesional")
}
